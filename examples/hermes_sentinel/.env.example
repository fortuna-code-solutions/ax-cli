# hermes_sentinel example — environment template
# Copy to .env and fill in the values for your setup.

# ─── LLM provider ──────────────────────────────────────────────────────────
# Pick one. Default is Codex (GPT-5.x) via the ChatGPT Codex backend.

# Anthropic Claude (recommended for general-purpose agents)
# ANTHROPIC_API_KEY=sk-ant-...
# HERMES_MODEL=anthropic:claude-sonnet-4.6

# Codex (GPT-5.x) — uses ChatGPT Codex bearer token
# CODEX_API_KEY=...
# HERMES_MODEL=codex:gpt-5.4

# OpenRouter (broad model catalog, single key)
# OPENROUTER_API_KEY=sk-or-...
# HERMES_MODEL=openrouter:anthropic/claude-sonnet-4.6

# ─── Hermes runtime ────────────────────────────────────────────────────────
# Absolute path to your local hermes-agent checkout.
HERMES_REPO_PATH=/path/to/hermes-agent

# Max number of tool-calling turns before the agent must return.
# Bump up for tasks that involve a lot of code reading or multi-file edits.
HERMES_MAX_ITERATIONS=30

# Working directory for the agent's file tools. Relative paths from the
# agent resolve against this. Defaults to the current directory if unset.
HERMES_WORKDIR=/path/to/your/workspace

# System prompt. Keep it short — you're giving the agent its job, not
# a manual. The default tells the agent to keep replies under 2000 chars
# since aX renders them as chat messages.
# HERMES_SYSTEM_PROMPT="You are a code review assistant. ..."

# ─── aX agent ──────────────────────────────────────────────────────────────
# These are consumed by `ax listen`, not this script directly. Put them in
# your project-local .ax/config.toml or global ~/.ax/config.toml instead.
#
# AX_TOKEN=axp_u_...      # PAT issued by aX for your agent
# AX_BASE_URL=https://next.paxai.app
# AX_AGENT_NAME=my_agent
# AX_AGENT_ID=...         # from `ax agents list`
# AX_SPACE_ID=...
